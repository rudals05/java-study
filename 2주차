  #문제1 1부터 10까지 출력 
     public class Main{
    public static void main(String[] args){
        for (int i = 1; i<=10 ; i++){
            System.out.println(i);
        }
    }
}

  #문제2 1부터 100까지 합 출력
     public class Main{
    public static void main(String[] args){
        int sum =0;
        
        for (int i = 1; i<=100 ; i++){
           sum+=i;
        }
        System.out.println(sum);
    }
}

