#day4 객체 활용
  #문제 1 Book객체 3개 만들고  printinfo() 호출
    class Book{
    String title;
    String author;
    int price;
    
    Book(String title,String author,int price){
        this.title=title;
        this.author=author;
        this.price=price;
    }
    
    void printInfo(){
        System.out.println(title+" "+author+" "+price);
    }
}
public class Main{
    public static void main(String[] args){
        Book b1 =new Book("어린왕자","생택쥐페리",5000);
