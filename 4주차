  #문제 1 Book 클래스에 printInfo() 메서드 추가 이름 저자 가격 출력
    class Book {
    String title;
    int price;
    String author;
    
    void printInfo(){
        System.out.println("제목은: "+title+" 저자는: "+author+" 가격은: "+price);
    }
}
public class Main{
    public static void main(String[] args){
        Book b1 =new Book();
        b1.title="경민의 자바일지";
        b1.price=777;
        b1.author="박경민";
        b1.printInfo();
    }
}
