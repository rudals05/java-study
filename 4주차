        Book b3= new Book("데미안","헤르만 헤세",4000);
        b1.printInfo();
        b2.printInfo();
        b3.printInfo();
    }
}
  #문제 2 객체 배열 해보기
    예:
    Student[] students ={ 
      new Student("kim",20),new Student("Lee",21)
    };

        class Student{
    String name;
    int age;
    
    Student(String name, int age){
        this.name = name;
        this.age=age;
    }
    
    void introduce(){
        System.out.println(name+" "+age);
    }
}
public class Main{
    public static void main(String[] args){
        Student[] students ={ 
            new Student("kim",20),new Student("Lee",21)};
            
        for(int i=0;i<students.length;i++){
            students[i].introduce();
        }
    }
}

