    }
}

  #문제 3 배열의 최솟값 구하기
    public class Main{
    public static void main(String[] args){
        int[] nums= {14,22,13,421,55,60};
        int min=nums[0];
        for(int i=1;i<nums.length; i++){
            if(nums[i]<min){
                min=nums[i];
            }
        }
        
        System.out.println("배열의 최솟값: "+ min);
    }
}
  #문제 4 배열 안에 특정 숫자가 몇개인지 세기 ex) {1,2,3,2,4,2}
    public class Main{
    public static void main(String[] args){
        int[] nums= {1,2,3,2,4,2};
        int num=2;
        int cnt=0;
        for(int i=0;i<nums.length; i++){
            if(nums[i]==num){
                cnt++;
            }
        }
        
        System.out.println("배열안에 2의 개수: "+ cnt);
    }
}

#day 5 종합 실습
  #문제 a 점수 배열을 만들고 메서드를 사용해 총점,평균,최댓값 출력하기
    public class Main{
    public static int getSum(int[] arr){
        int sum=0;
        for(int i=0;i<arr.length;i++){
            sum+=arr[i];
        }
        return sum;
    }
    public static double getAvg(int[] arr){
        return getSum(arr)/arr.length;
    }
    public static int getMax(int[] arr){
        int max=arr[0];
        for(int i=1; i<arr.length;i++){
            if (arr[i]>max){
                max = arr[i];
            }
        }
        return max;
    }
    
    
    
    public static void main(String[] args){
      int[] scores={80,90,75,100,60};
      System.out.println("점수의 총합은: "+getSum(scores));
      System.out.println("점수의 평균은: "+getAvg(scores));
      System.out.println("점수의 최댓값은: "+getMax(scores));
    }
}


