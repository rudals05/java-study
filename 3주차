#day 2 매개변수와 반환값
  #문제 1 subtract(int a,int b) 만들어서 뺄셈 결과 반환
      public class Main {
    public static int subtract(int a,int b){
        return a-b;
    }
    public static void main(String[] args){
        int result = subtract(12,4);
        System.out.println(result);
    }
}
  #문제 2 multiply(int a,int b)만들어서 곱셈 결과반환
    public class Main {
    public static int multiply(int a,int b){
        return a*b;
    }
    public static void main(String[] args){
        int result = multiply(12,4);
        System.out.println(result);
    }
}

  #문제 3 isEven(int a) 만들어서 짝수면 true 아니면 false
    public class Main {
    public static boolean isEven(int a){
        if(a%2==0){
            return true;
        }
        else{
            return false;
        }
    }
    public static void main(String[] args){
        
        System.out.println(isEven(225));
    }
}
  #문제 4 getMax(int a, int b) 만들어서 큰 값 반환
    public class Main {
    public static int getMax(int a,int b){
        if(a>b){
            return a;
        }
        else{
            return b;
        }
    }
    public static void main(String[] args){
        int result =getMax(241,256);
        System.out.println(result);
    }
}

#day3 배열 기본  
  #문제1 배열{1,2,3,4,5} 선언하고 모두 출력
    public class Main{
    public static void main(String[] args){
        int[] nums = {1,2,3,4,5};
        
        for(int i=0; i<nums.length;i++){
            System.out.println(nums[i]);
        }
    }
}
  #문제 2 배열{5,10,15} 선언하고 각값에 2를 더해 출력
    public class Main{
    public static void main(String[] args){
        int[] nums = {5,10,15};
        
        for(int i=0; i<nums.length;i++){
            System.out.println(nums[i]+2);
        }
    }
}
