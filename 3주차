    }
}

  #문제 2 배열의 평균 구하기
    public class Main{
    public static void main(String[] args){
        int[] nums= {1,2,3,4,5,6};
        int sum=0;
        for(int i=0;i<nums.length; i++){
            sum+=nums[i];
